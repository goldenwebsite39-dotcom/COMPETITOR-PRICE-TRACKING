{
  "entities": {
    "Product": {
      "title": "Product",
      "description": "An eCommerce product sold by Golden Cloud.",
      "type": "object",
      "properties": {
        "name": { "type": "string", "description": "Product name" },
        "sku": { "type": "string", "description": "Unique SKU or model number" },
        "category": { "type": "string", "description": "Product category (e.g., GPUs, CPUs)" },
        "costPrice": { "type": "number", "description": "Acquisition cost" },
        "currentPrice": { "type": "number", "description": "Current selling price" },
        "image": { "type": "string", "description": "Product image URL" }
      },
      "required": ["name", "sku", "category", "costPrice", "currentPrice"]
    },
    "CompetitorPrice": {
      "title": "Competitor Price",
      "description": "A price record from a competitor website.",
      "type": "object",
      "properties": {
        "productId": { "type": "string", "description": "Reference to the Product ID" },
        "competitorName": { "type": "string", "description": "Name of the competitor (e.g., Amazon, Noon)" },
        "price": { "type": "number", "description": "Price found on competitor site" },
        "url": { "type": "string", "description": "URL to the competitor's product page" },
        "timestamp": { "type": "string", "format": "date-time", "description": "When the price was fetched" }
      },
      "required": ["productId", "competitorName", "price", "url", "timestamp"]
    },
    "Alert": {
      "title": "Alert",
      "description": "A pricing or market alert.",
      "type": "object",
      "properties": {
        "type": { "type": "string", "enum": ["critical", "market", "inventory", "rule"], "description": "Type of alert" },
        "title": { "type": "string", "description": "Alert title" },
        "description": { "type": "string", "description": "Detailed alert message" },
        "productId": { "type": "string", "description": "Optional product reference" },
        "marketAvg": { "type": "number", "description": "Optional market average price" },
        "yourPrice": { "type": "number", "description": "Optional current price" },
        "volatility": { "type": "number", "description": "Optional volatility index" },
        "timestamp": { "type": "string", "format": "date-time", "description": "When the alert was generated" }
      },
      "required": ["type", "title", "description", "timestamp"]
    }
  },
  "firestore": {
    "/products/{productId}": {
      "schema": "Product",
      "description": "Collection of products."
    },
    "/competitor_prices/{priceId}": {
      "schema": "CompetitorPrice",
      "description": "History of competitor prices."
    },
    "/alerts/{alertId}": {
      "schema": "Alert",
      "description": "System generated alerts."
    }
  }
}
